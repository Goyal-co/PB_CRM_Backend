{
  "name": "orchid-life-crm-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && nest build",
    "start": "node dist/main",
    "start:dev": "node scripts/free-dev-port.cjs && nest start --watch",
    "dev:login": "node scripts/dev-login.cjs",
    "start:prod": "node dist/main",
    "start:nest": "nest start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:e2e:core": "jest --config ./test/jest-e2e.json --runInBand --forceExit test/01-auth.e2e-spec.ts test/02-projects.e2e-spec.ts test/03-profiles.e2e-spec.ts test/04-manager-projects.e2e-spec.ts test/05-units.e2e-spec.ts test/06-form-templates.e2e-spec.ts test/07-agreement-templates.e2e-spec.ts test/16-dashboard.e2e-spec.ts test/20-admin-workflow.e2e-spec.ts test/21-cleanup.e2e-spec.ts",
    "test:e2e:watch": "jest --config ./test/jest-e2e.json --runInBand --watch"
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^5.2.0",
    "@supabase/supabase-js": "^2.49.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^4.28.1",
    "puppeteer": "^24.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
