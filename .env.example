# Application
NODE_ENV=production
PORT=3000
APP_URL=https://api.orchidlife.in

# When 1, POST /api/v1/admin/invitations also sends supabase.auth.admin.inviteUserByEmail
ADMIN_SEND_INVITE_EMAIL=0

# One-time: POST /api/v1/auth/bootstrap-admin (first super_admin only). Leave empty to disable. Rotate/remove after onboarding.
BOOTSTRAP_ADMIN_SECRET=

# Supabase (replace with your project values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Settings → "Legacy JWT secret (still used)" — copy the revealed value
SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# Supabase Storage base URL (optional; derived from SUPABASE_URL if omitted)
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# Storage buckets are fixed in code to match your Supabase project:
#   kyc-documents (private, 10 MB), agreements (private, 50 MB, PDF only),
#   floor-plans (public, 20 MB), payment-receipts (private, 10 MB)

# Email — transactional notifications (Supabase sends auth emails separately)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orchidlifecrm@goyalco.com
SMTP_PASS=your-app-password
FROM_EMAIL=orchidlifecrm@goyalco.com

# Rate limiting (per IP)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,https://crm.orchidlife.in

# E2E (npm run test:e2e) — optional; defaults shown match auto-bootstrap in test/helpers/e2e-bootstrap.ts
TEST_E2E_BOOTSTRAP=1
TEST_BASE_URL=http://127.0.0.1:3000
TEST_SUPER_ADMIN_EMAIL=admin@gmail.com
TEST_SUPER_ADMIN_PASSWORD=admin1234
TEST_MANAGER_EMAIL=manager1@gmail.com
TEST_MANAGER_PASSWORD=manager1234
TEST_USER_EMAIL=user1@gmail.com
TEST_USER_PASSWORD=user1234
TEST_MANAGER_2_EMAIL=manager2@gmail.com
TEST_MANAGER_2_PASSWORD=manager2234
TEST_USER_2_EMAIL=user2@gmail.com
TEST_USER_2_PASSWORD=user2234
TEST_USER_3_EMAIL=user3@gmail.com
TEST_USER_3_PASSWORD=user3234
TEST_USER_4_EMAIL=user4@gmail.com
TEST_USER_4_PASSWORD=user4234
